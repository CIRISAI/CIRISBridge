# Caddy Configuration - Test Environment
# Auto-generated by Ansible

{
    email {{ caddy_email }}
    acme_ca https://acme-v02.api.letsencrypt.org/directory
}

{% if 'test_infra' in group_names %}
# CIRISLens - Test Environment
lens-test.{{ primary_domain }} {
    # Public accord repository endpoints (no auth required) — CANONICAL
    # These are served directly without the /lens-api prefix
    handle /api/v1/accord/* {
        reverse_proxy cirislens-api:8000
    }

    # Deprecated alias — kept for backward compat
    handle /api/v1/covenant/* {
        reverse_proxy cirislens-api:8000
    }

    # CIRISLens API routes (via /lens-api prefix)
    handle /lens-api/* {
        uri strip_prefix /lens-api
        reverse_proxy cirislens-api:8000
    }

    # Grafana (everything else)
    handle {
        reverse_proxy cirislens-grafana:3000
    }

    header {
        Strict-Transport-Security "max-age=31536000"
        X-Content-Type-Options nosniff
        -Server
    }

    log {
        output file /var/log/caddy/lens-test.log
        format json
    }
}
{% endif %}

{% if 'test_services' in group_names %}
# CIRISBilling - Test Environment
billing-test.{{ primary_domain }} {
    reverse_proxy ciris-billing:8000 {
        health_uri /health
        health_interval 30s
    }

    header {
        Strict-Transport-Security "max-age=31536000"
        X-Content-Type-Options nosniff
        -Server
    }

    log {
        output file /var/log/caddy/billing-test.log
        format json
    }
}

# CIRISProxy - Test Environment
proxy-test.{{ primary_domain }} {
    reverse_proxy ciris-proxy:4000

    header {
        Strict-Transport-Security "max-age=31536000"
        X-Content-Type-Options nosniff
        -Server
    }

    log {
        output file /var/log/caddy/proxy-test.log
        format json
    }
}
{% endif %}

{% if 'test_scout' in group_names %}
# CIRISManager - Test Environment
# Manager runs on host, Caddy in Docker - use Docker bridge gateway
scout-test.{{ primary_domain }} {
    reverse_proxy 172.17.0.1:{{ manager_port | default(8090) }}

    header {
        Strict-Transport-Security "max-age=31536000"
        X-Content-Type-Options nosniff
        -Server
    }

    log {
        output file /var/log/caddy/scout-test.log
        format json
    }
}
{% endif %}
