# Caddy TLS Termination - Auto-generated by Ansible

services:
  caddy:
    image: caddy:2-alpine
    container_name: ciris-caddy
    restart: unless-stopped
    ports:
      - "80:80"
      - "443:443"
      - "443:443/udp"  # HTTP/3
    volumes:
      - ./Caddyfile:/etc/caddy/Caddyfile:ro
      - ./data:/data
      - ./config:/config
      - ./certs:/opt/ciris/caddy/certs:ro
    environment:
      CADDY_INGRESS_NETWORKS: ciris
{% if ciris_environment | default('production') == 'test' %}
    # Test environment - use local networks
    networks:
      - caddy
{% if 'test_services' in group_names %}
      - billing
{% endif %}
{% if 'test_infra' in group_names %}
      - lens
{% endif %}
{% else %}
    networks:
      - ciris
{% if inventory_hostname == 'vultr' %}
      - lens  # For CIRISLens API access
{% endif %}
{% endif %}
    healthcheck:
      test: ["CMD", "caddy", "version"]
      interval: 30s
      timeout: 10s
      retries: 3
    extra_hosts:
      - "host.docker.internal:host-gateway"

networks:
{% if ciris_environment | default('production') == 'test' %}
  caddy:
    driver: bridge
{% if 'test_services' in group_names %}
  billing:
    external: true
    name: billing_billing
{% endif %}
{% if 'test_infra' in group_names %}
  lens:
    external: true
    name: lens_cirislens
{% endif %}
{% else %}
  ciris:
    external: true
    name: postgres_ciris
{% if inventory_hostname == 'vultr' %}
  lens:
    external: true
    name: lens_cirislens
{% endif %}
{% endif %}
