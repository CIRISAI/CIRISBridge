# CIRISManager Configuration
# Auto-generated by Ansible for {{ environment | default('test') }} environment

# API Server
api:
  host: "{{ manager_api_host }}"
  port: {{ manager_api_port }}

# Data directories
paths:
  data_dir: "{{ manager_data_dir }}"
  agents_dir: "{{ manager_data_dir }}/agents"
  log_dir: "{{ manager_log_dir }}"
  config_dir: "{{ manager_config_dir }}"

# Agent servers (Docker hosts)
servers:
  # Local server (this machine runs agents directly)
  local:
    type: local
    docker_socket: /var/run/docker.sock

{% if agent_servers is defined %}
{% for server in agent_servers %}
  {{ server.name }}:
    type: remote
    host: "{{ server.host }}"
    docker_host: "tcp://{{ server.docker_host }}:2376"
    tls_verify: true
    tls_cert_path: "{{ manager_config_dir }}/docker-certs/{{ server.name }}"
{% endfor %}
{% endif %}

# CIRIS Service Integration
services:
  billing:
    url: "{{ billing_api_url }}"
{% if test_auth_token is defined %}
    auth_token: "{{ test_auth_token }}"
{% endif %}

  proxy:
    url: "{{ proxy_api_url }}"
{% if test_auth_token is defined %}
    auth_token: "{{ test_auth_token }}"
{% endif %}

  lens:
    url: "{{ cirislens_endpoint | default('https://lens-test.' + primary_domain + '/lens-api/api/v1/logs/ingest') }}"
    token: "{{ cirislens_token | default('') }}"
    # Send manager telemetry to lens
    enabled: true
    metrics_interval: 30

# Adapters Configuration
adapters:
  # Covenant Metrics Adapter - reports CIRIS Covenant compliance metrics
  covenant_metrics:
    enabled: true
    lens_endpoint: "{{ cirislens_endpoint | default('https://lens-test.' + primary_domain + '/lens-api/api/v1/logs/ingest') }}"
    lens_token: "{{ cirislens_token | default('') }}"
    metrics:
      - deontic_alignment       # Ethical principle alignment
      - coherence_score         # Adaptive coherence metric
      - task_success_rate       # Task completion metrics
      - resource_utilization    # Resource efficiency

# Agent defaults
agent_defaults:
  # Test auth for billing integration
{% if billing_test_auth_enabled | default(false) %}
  billing_auth:
    enabled: true
    token: "{{ test_auth_token }}"
    user_id: "{{ test_user_id | default('ciris_test_canary') }}"
    oauth_provider: "oauth:test"
{% endif %}

  # Default resource limits
  resources:
    memory_limit: "2g"
    cpu_limit: "1.0"

  # Network mode
  network_mode: bridge

# Logging
logging:
  level: INFO
  format: "%(asctime)s - %(name)s - %(levelname)s - %(message)s"

# Environment
environment: {{ environment | default('test') }}
