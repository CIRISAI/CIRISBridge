# CIRISManager Configuration
# Auto-generated by Ansible for {{ ciris_environment | default('test') }} environment

# Manager settings
manager:
  host: "{{ manager_api_host | default('0.0.0.0') }}"
  port: {{ manager_api_port | default(8888) }}
  agents_directory: "{{ manager_data_dir }}/agents"
  templates_directory: "{{ manager_install_dir }}/agent_templates"
  manifest_path: "{{ manager_install_dir }}/pre-approved-templates.json"

# Authentication settings
auth:
{% if manager_dev_mode | default(false) %}
  mode: development
{% else %}
  mode: production
{% endif %}

# Docker settings
docker:
  registry: ghcr.io/cirisai
  image: ciris-agent:latest

# Multi-server configuration
servers:
  - server_id: local
    hostname: localhost
    is_local: true

# Port allocation
ports:
  start: 8000
  end: 8999
  reserved: [8080, 8888, 8090]

# Watchdog settings
watchdog:
  check_interval: 30
  crash_threshold: 3
  crash_window: 300

# Container management
container_management:
  interval: 300
  pull_images: false

# Nginx settings
nginx:
  enabled: true
  config_dir: /etc/nginx/sites-enabled
  container_name: ciris-nginx
