# CIRISProxy Environment - Auto-generated by Ansible
# DO NOT COMMIT

# Module loading (ensures callbacks can be imported)
PYTHONPATH=/app

# LiteLLM
LITELLM_CONFIG_PATH=/app/config.yaml
LITELLM_MASTER_KEY={{ litellm_master_key }}
LITELLM_LOG_LEVEL={{ litellm_log_level | default('INFO') }}

# CIRISBilling integration (via Docker host gateway - billing uses host networking)
BILLING_API_URL=http://host.docker.internal:8000
BILLING_API_KEY={{ billing_api_key }}

# LLM Providers (ZDR - Zero Data Retention)
{% if groq_api_key is defined %}
GROQ_API_KEY={{ groq_api_key }}
{% endif %}
{% if together_api_key is defined %}
TOGETHER_API_KEY={{ together_api_key }}
{% endif %}
{% if openrouter_api_key is defined %}
OPENROUTER_API_KEY={{ openrouter_api_key }}
{% endif %}
{% if openrouter_ignore_providers is defined %}
OPENROUTER_IGNORE_PROVIDERS={{ openrouter_ignore_providers }}
{% endif %}
{% if nvidia_nim_api_key is defined %}
NVIDIA_NIM_API_KEY={{ nvidia_nim_api_key }}
{% endif %}
{% if openai_api_key is defined and openai_api_key %}
OPENAI_API_KEY={{ openai_api_key }}
{% endif %}

# Google OAuth Client IDs (for token validation)
{% if proxy_google_client_id is defined %}
GOOGLE_CLIENT_ID={{ proxy_google_client_id }}
{% endif %}
{% if proxy_google_client_id_android is defined %}
GOOGLE_CLIENT_ID_ANDROID={{ proxy_google_client_id_android }}
{% endif %}

# Web Search
{% if brave_api_key is defined %}
BRAVE_API_KEY={{ brave_api_key }}
{% endif %}
{% if exa_api_key is defined %}
EXA_API_KEY={{ exa_api_key }}
{% endif %}

# Cloudflare Tunnel (optional)
{% if cloudflare_tunnel_token is defined and cloudflare_tunnel_token %}
CLOUDFLARE_TUNNEL_TOKEN={{ cloudflare_tunnel_token }}
{% endif %}

# Logging
CIRIS_LOG_FILE=/app/logs/cirisproxy.log
CIRIS_LOG_LEVEL=INFO

# Test Auth Mode (for integration testing - NEVER enable in production)
{% if proxy_test_auth_enabled | default(false) %}
CIRIS_TEST_AUTH_ENABLED=true
CIRIS_TEST_USER_ID={{ proxy_test_user_id | default('ciris_synthetic_canary') }}
{% endif %}

# CIRISLens (observability)
{% if proxy_cirislens_token is defined %}
CIRISLENS_TOKEN={{ proxy_cirislens_token }}
CIRISLENS_ENDPOINT={{ proxy_cirislens_endpoint | default('https://lens.' + primary_domain + '/lens-api/api/v1/logs/ingest') }}
{% endif %}
