# CIRISProxy - Auto-generated by Ansible

services:
  proxy:
    image: {{ proxy_image }}
    container_name: ciris-proxy
    restart: unless-stopped
    command: ["--port", "4000", "--config", "/app/config.yaml"]
    ports:
      - "127.0.0.1:{{ proxy_port }}:4000"
    env_file:
      - .env
    volumes:
      - ./litellm_config.yaml:/app/config.yaml:ro
      - /var/log/ciris/proxy:/app/logs
{% if ciris_environment | default('production') == 'test' %}
    networks:
      - billing
{% else %}
    networks:
      - ciris
{% endif %}
    healthcheck:
      test: ["CMD", "python", "/app/healthcheck.py"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 15s

networks:
{% if ciris_environment | default('production') == 'test' %}
  billing:
    external: true
    name: billing_billing
{% else %}
  ciris:
    external: true
    name: postgres_ciris
{% endif %}
