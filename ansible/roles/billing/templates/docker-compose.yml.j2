# CIRISBilling - Auto-generated by Ansible

services:
  billing:
    image: {{ billing_image }}
    container_name: ciris-billing
    restart: unless-stopped
    env_file:
      - .env
    volumes:
      - /var/log/ciris/billing:/app/logs
{% if ciris_environment | default('production') == 'test' %}
    ports:
      - "127.0.0.1:{{ billing_port }}:8000"
    networks:
      - billing
{% else %}
    # Production: Use host networking for direct access to Spock postgres (127.0.0.1:5433)
    network_mode: host
{% endif %}
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:8000/health"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 30s

{% if ciris_environment | default('production') == 'test' %}
networks:
  billing:
    driver: bridge
{% endif %}
