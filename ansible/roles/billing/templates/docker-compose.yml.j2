# CIRISBilling - Auto-generated by Ansible

services:
  billing:
    image: {{ billing_image }}
    container_name: ciris-billing
    restart: unless-stopped
    ports:
      - "127.0.0.1:{{ billing_port }}:8000"
    env_file:
      - .env
    volumes:
      - /var/log/ciris/billing:/app/logs
{% if ciris_environment | default('production') == 'test' %}
    networks:
      - billing
{% else %}
    networks:
      - ciris
{% endif %}
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:8000/health"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 30s

networks:
{% if ciris_environment | default('production') == 'test' %}
  billing:
    driver: bridge
{% else %}
  ciris:
    external: true
    name: postgres_ciris
{% endif %}
