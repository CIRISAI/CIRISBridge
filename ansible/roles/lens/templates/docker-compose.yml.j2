# CIRISLens - Observability Platform
# Auto-generated by Ansible
#
# Components:
# - TimescaleDB: Time-series storage with compression
# - Grafana: Visualization dashboards
# - CIRISLens API: Log ingestion + admin UI

services:
  # ==========================================================================
  # TimescaleDB - Time-series storage
  # ==========================================================================
  postgres:
    image: timescale/timescaledb:latest-pg15
    container_name: cirislens-db
    restart: unless-stopped
    environment:
      POSTGRES_USER: {{ lens_db_user | default('cirislens') }}
      POSTGRES_PASSWORD: {{ lens_db_password }}
      POSTGRES_DB: {{ lens_db_name | default('cirislens') }}
    volumes:
      - /data/cirislens/postgres:/var/lib/postgresql/data
      - ./sql:/docker-entrypoint-initdb.d:ro
    networks:
      - cirislens
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U {{ lens_db_user | default('cirislens') }}"]
      interval: 10s
      timeout: 5s
      retries: 5

  # ==========================================================================
  # Grafana - Visualization
  # ==========================================================================
  grafana:
    image: grafana/grafana:{{ lens_grafana_version | default('latest') }}
    container_name: cirislens-grafana
    restart: unless-stopped
    environment:
      # Admin credentials
      GF_SECURITY_ADMIN_USER: {{ lens_grafana_admin_user | default('admin') }}
      GF_SECURITY_ADMIN_PASSWORD: {{ lens_grafana_admin_password }}
      GF_SECURITY_SECRET_KEY: {{ lens_grafana_secret_key }}
      # Server configuration
{% if ciris_environment | default('production') == 'test' %}
      GF_SERVER_ROOT_URL: https://lens-test.{{ primary_domain }}
      GF_SERVER_DOMAIN: lens-test.{{ primary_domain }}
{% else %}
      GF_SERVER_ROOT_URL: https://lens.{{ primary_domain }}
      GF_SERVER_DOMAIN: lens.{{ primary_domain }}
{% endif %}
      # Database (use TimescaleDB instead of SQLite)
      GF_DATABASE_TYPE: postgres
      GF_DATABASE_HOST: postgres:5432
      GF_DATABASE_NAME: grafana
      GF_DATABASE_USER: {{ lens_db_user | default('cirislens') }}
      GF_DATABASE_PASSWORD: {{ lens_db_password }}
      GF_DATABASE_SSL_MODE: disable
      # Authentication
      GF_AUTH_ANONYMOUS_ENABLED: {{ 'true' if lens_public_dashboards | default(false) else 'false' }}
      GF_AUTH_ANONYMOUS_ORG_ROLE: Viewer
      GF_AUTH_DISABLE_LOGIN_FORM: false
{% if lens_google_oauth_enabled | default(false) %}
      # Google OAuth
      GF_AUTH_GOOGLE_ENABLED: true
      GF_AUTH_GOOGLE_CLIENT_ID: {{ lens_google_client_id }}
      GF_AUTH_GOOGLE_CLIENT_SECRET: {{ lens_google_client_secret }}
      GF_AUTH_GOOGLE_SCOPES: openid email profile
      GF_AUTH_GOOGLE_AUTH_URL: https://accounts.google.com/o/oauth2/auth
      GF_AUTH_GOOGLE_TOKEN_URL: https://oauth2.googleapis.com/token
      GF_AUTH_GOOGLE_ALLOWED_DOMAINS: {{ lens_allowed_domain | default('ciris.ai') }}
      GF_AUTH_GOOGLE_ALLOW_SIGN_UP: true
{% endif %}
      # Features
      GF_FEATURE_TOGGLES_ENABLE: traceToMetrics,traceToLogs,correlations
      GF_EXPLORE_ENABLED: true
      GF_UNIFIED_ALERTING_ENABLED: true
    volumes:
      - /data/cirislens/grafana:/var/lib/grafana
      - ./config/grafana/provisioning:/etc/grafana/provisioning:ro
      - ./dashboards:/var/lib/grafana/dashboards:ro
    ports:
      - "127.0.0.1:3001:3000"
    networks:
      - cirislens
      - ciris
    depends_on:
      postgres:
        condition: service_healthy

  # ==========================================================================
  # CIRISLens API - Log ingestion + Admin UI
  # ==========================================================================
  api:
    image: {{ lens_api_image | default('ghcr.io/cirisai/cirislens-api:latest') }}
    container_name: cirislens-api
    restart: unless-stopped
    environment:
      DATABASE_URL: postgresql://{{ lens_db_user | default('cirislens') }}:{{ lens_db_password | regex_replace('/', '%2F') }}@postgres:5432/{{ lens_db_name | default('cirislens') }}
      ENV: production
      # OAuth for admin UI (lens reads OAUTH_*, not GOOGLE_*)
      OAUTH_CLIENT_ID: {{ google_client_id | default('') }}
      OAUTH_CLIENT_SECRET: {{ google_client_secret | default('') }}
{% if ciris_environment | default('production') == 'test' %}
      OAUTH_CALLBACK_URL: https://lens-test.{{ primary_domain }}/api/admin/auth/callback
{% else %}
      OAUTH_CALLBACK_URL: https://lens.{{ primary_domain }}/api/admin/auth/callback
{% endif %}
      ALLOWED_DOMAIN: {{ lens_allowed_domain | default('ciris.ai') }}
      SESSION_SECRET: {{ lens_session_secret }}
      # Collection settings
      COLLECTION_INTERVAL_SECONDS: {{ lens_collection_interval | default(30) }}
      OTLP_COLLECTION_ENABLED: false
      # Status collector (multi-region monitoring)
{% if ciris_environment | default('production') == 'test' %}
      # Test environment - single region
      US_BILLING_URL: https://billing-test.{{ primary_domain }}
      US_PROXY_URL: https://proxy-test.{{ primary_domain }}
      EU_BILLING_URL: ""
      EU_PROXY_URL: ""
      # Infrastructure health checks
      VULTR_HEALTH_URL: https://billing-test.{{ primary_domain }}/health
      HETZNER_HEALTH_URL: ""
{% else %}
      # US Region (Vultr Chicago) - internal for local, external for cross-region
      US_BILLING_URL: https://billing1.{{ primary_domain }}
      US_PROXY_URL: https://llm01.{{ primary_domain }}
      # EU Region (Hetzner Germany) - uses different domain structure
      EU_BILLING_URL: https://billing1.{{ eu_domain | default('ciris-services-eu-1.com') }}
      EU_PROXY_URL: https://llm01.{{ eu_domain | default('ciris-services-eu-1.com') }}
      # Infrastructure health checks
      VULTR_HEALTH_URL: https://billing1.{{ primary_domain }}/health
      HETZNER_HEALTH_URL: https://billing1.{{ eu_domain | default('ciris-services-eu-1.com') }}/health
{% endif %}
      GHCR_HEALTH_URL: https://ghcr.io/v2/
      GRAFANA_URL: http://grafana:3000
      # External service health checks
      EXA_HEALTH_URL: https://api.exa.ai/health
      # Scrub signing key for tamper-evident PII removal
      CIRISLENS_SCRUB_KEY_PATH: /app/keys/scrub_private.key
      # Federation steward identity — Ed25519 seed used by persist's
      # engine.steward_sign() hot path for federation_keys mirror writes.
      # Bridge ran the lens-steward bootstrap (runbooks/lens-steward-bootstrap.yml)
      # ahead of this rollout, so the FK target row exists in cirislens.federation_keys.
      # STEWARD_KEY_ID defaults to "lens-steward" — only the path is required.
      CIRISLENS_STEWARD_KEY_PATH: /app/keys/lens-steward.seed
      # Federation steward PQC identity — ML-DSA-65 seed for the cold-path
      # PQC sign (persist 0.3.1+). Persist's cold-path worker calls
      # attach_key_pqc_signature() on hybrid-pending rows after Ed25519
      # write, completing the (canonical || classical_sig) hybrid binding.
      # Backfilled rows from the migrator + new agent registrations both
      # depend on this to reach pqc_completed_at != NULL state.
      CIRISLENS_STEWARD_PQC_KEY_PATH: /app/keys/lens-steward.mldsa.secret
      # Scrubber v2 divergence log (persisted to host via /var/log/ciris/lens mount)
      CIRISLENS_SCRUBBER_DIVERGENCE_LOG: /app/logs/scrubber_divergence.jsonl
      # Persistent keyring for SoftwareSigner — guarantees stable lens identity across restarts
      CIRIS_DATA_DIR: /var/lib/cirislens/keyring
      # Phase 2a flag — ON for 61da62f capture (lens-side body_sha256_prefix
      # added to PERSIST_DELEGATE_REJECT lines; cross-layer join key for v0.1.18).
      CIRISLENS_USE_PERSIST_ENGINE: "true"
      RUST_LOG: ciris_persist=warn
    volumes:
      - /var/log/ciris/lens:/app/logs
      - /opt/ciris/lens/keys:/app/keys:ro
      - /data/cirislens/keyring:/var/lib/cirislens/keyring
    ports:
      - "127.0.0.1:8200:8000"
    networks:
      - cirislens
      - ciris
    depends_on:
      postgres:
        condition: service_healthy
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:8000/health"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 30s

networks:
  cirislens:
    driver: bridge
  ciris:
    external: true
    name: postgres_ciris
