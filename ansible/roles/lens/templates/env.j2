# CIRISLens Environment Configuration
# Auto-generated by Ansible

# Database
POSTGRES_USER={{ lens_db_user | default('cirislens') }}
POSTGRES_PASSWORD={{ lens_db_password }}
POSTGRES_DB={{ lens_db_name | default('cirislens') }}

# API
DATABASE_URL=postgresql://{{ lens_db_user | default('cirislens') }}:{{ lens_db_password | regex_replace('/', '%2F') }}@postgres:5432/{{ lens_db_name | default('cirislens') }}
SESSION_SECRET={{ lens_session_secret }}

# OAuth (for admin UI)
GOOGLE_CLIENT_ID={{ google_client_id | default('') }}
GOOGLE_CLIENT_SECRET={{ google_client_secret | default('') }}
ALLOWED_DOMAIN={{ lens_allowed_domain | default('ciris.ai') }}

# Grafana
GF_ADMIN_USER={{ lens_grafana_admin_user | default('admin') }}
GF_ADMIN_PASSWORD={{ lens_grafana_admin_password }}
GF_SECRET_KEY={{ lens_grafana_secret_key }}

# Collection
COLLECTION_INTERVAL_SECONDS={{ lens_collection_interval | default(30) }}

# Status Collector (aggregates status from all services)
BILLING_STATUS_URL=http://ciris-billing:8000
PROXY_STATUS_URL=http://ciris-proxy:4000

# Public Status Page - Region service URLs
{% if ciris_environment | default('production') == 'test' %}
US_BILLING_URL=https://billing-test.{{ primary_domain }}
US_PROXY_URL=https://proxy-test.{{ primary_domain }}
EU_BILLING_URL=
EU_PROXY_URL=
{% else %}
US_BILLING_URL=https://billing1.{{ primary_domain }}
US_PROXY_URL=https://proxy1.{{ primary_domain }}
EU_BILLING_URL=https://billing1.{{ secondary_domain }}
EU_PROXY_URL=https://proxy1.{{ secondary_domain }}
{% endif %}

# External service health checks
EXA_HEALTH_URL=https://api.exa.ai/health
