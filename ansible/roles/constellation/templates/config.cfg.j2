# Constellation DNS Server Configuration
# Active/Active with GeoDNS Routing
# Auto-generated by Ansible for {{ node_name }} node

[server]
log_level = "info"
identifier = "ciris-dns/{{ node_name }}"

[dns]
inets = [
    "0.0.0.0:53"
]
tcp_timeout = 2

nameservers = [
    "ns1.{{ dns_soa }}",
    "ns2.{{ dns_soa }}"
]

soa_master = "ns1.{{ dns_soa }}"
soa_responsible = "admin.{{ dns_soa }}"
soa_refresh = 3600
soa_retry = 600
soa_expire = 86400
soa_ttl = 3600
record_ttl = 60

# Define authoritative zones
[dns.zone.'{{ primary_domain }}']
[dns.zone.'{{ secondary_domain }}']

[http]
inet = "0.0.0.0:8080"
workers = 2
record_token = "{{ constellation_api_token }}"

[redis]
database = 0
pool_size = 4
max_lifetime_seconds = 20
idle_timeout_seconds = 600
connection_timeout_seconds = 2

[redis.master]
host = "redis"
port = 6379

# =============================================================================
# Geographic Routing Configuration
# =============================================================================
[geo]
database_path = "/data/"
database_file = "dbip-country-lite.mmdb"
update_enable = false
update_interval = 864000


